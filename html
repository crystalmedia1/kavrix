<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Mijn Eigen App Builder</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white font-sans">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <div class="w-1/3 border-r border-gray-700 p-6 flex flex-col">
      <h2 class="text-xl font-bold mb-4">App Builder</h2>
      <p class="text-gray-400 mb-4 text-sm">Beschrijf de app die je wilt bouwen:</p>
      
      <textarea id="promptInput" class="flex-1 bg-gray-800 border border-gray-600 rounded-lg p-4 text-white resize-none" placeholder="Bijv: Bouw een todo-app met dark mode..."></textarea>
      
      <button id="buildBtn" class="mt-4 py-3 bg-indigo-600 hover:bg-indigo-500 rounded-lg font-semibold transition">
        Genereer App
      </button>
    </div>

    <!-- Preview Pane -->
    <div class="w-2/3 flex flex-col">
      <div class="bg-gray-800 p-2 border-b border-gray-700 flex justify-between items-center px-6">
        <span class="text-sm font-medium text-gray-400">Live Preview</span>
        <div class="flex space-x-2">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>
      </div>
      <iframe id="previewFrame" class="w-full h-full bg-white"></iframe>
    </div>
  </div>

  <script>
    document.getElementById("buildBtn").addEventListener("click", async () => {
      const prompt = document.getElementById("promptInput").value;
      if (!prompt) return;

      const res = await fetch("/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prompt })
      });

      const data = await res.json();
      document.getElementById("previewFrame").srcdoc = data.code;
    });
  </script>
</body>
</html>
